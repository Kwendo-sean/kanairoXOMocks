# The following logic finds and loads podhelper.rb
ios_dir = File.expand_path(File.dirname(__FILE__))
podhelper_path = File.join(ios_dir, 'Flutter', 'podhelper.rb')

if !File.exist?(podhelper_path)
  # Fallback to finding it via FLUTTER_ROOT in Generated.xcconfig
  generated_xcconfig_path = File.join(ios_dir, 'Flutter', 'Generated.xcconfig')
  if File.exist?(generated_xcconfig_path)
    File.foreach(generated_xcconfig_path) do |line|
      matches = line.match(/\AFLUTTER_ROOT=(.*)\z/)
      if matches
        podhelper_path = File.join(matches[1].strip, 'packages', 'flutter_tools', 'bin', 'podhelper.rb')
        break
      end
    end
  end
end

if File.exist?(podhelper_path)
  load podhelper_path
else
  # If still not found, try a common location or raise error
  raise "podhelper.rb not found at #{podhelper_path}. Please run 'flutter pub get' first."
end

platform :ios, '14.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = '1'

project 'Runner', {
  'Debug' => :debug,
  'Release' => :release,
  'Profile' => :profile,
}

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods ios_dir
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
    end
  end
end
